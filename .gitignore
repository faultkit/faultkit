# Build outputs
/bin/
/dist/
*.exe
*.test
*.out

# Go-specific
# vendor/ IS committed — builds run from it (-mod=vendor), per the
# supply-chain policy in CLAUDE.md.
*.prof
coverage.txt
coverage.html
*.cover

# eBPF build artifacts
# Note: bpf2go-generated .go files ARE committed (per V0.1_SPEC.md §3.1)
# but the intermediate .o objects are not. vmlinux.h is regenerated
# by `make bpf` from the local kernel's BTF; keeping it out of the
# repo avoids committing a 6+MB host-specific file.
*.bpf.o
/internal/inject/ebpf/gen/*.o
/bpf/vmlinux.h

# Test artifacts
/tmp/
/test/integration/tmp/

# Example deps and caches. Lockfiles ARE committed: package-lock.json pins
# the example deps so CI installs them with `npm ci` (exact, reproducible) —
# a supply-chain requirement, so it must not be ignored.
**/node_modules/
**/__pycache__/
**/.pytest_cache/

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Direnv / env files
.envrc
.env
.env.local

# faultkit-specific runtime artifacts that should never be committed
# (per-run CAs are written to OS temp dirs, but defensively ignore here too)
faultkit-ca-*.pem
*.faultkit-trace
report.json

# Private keys & credentials — never commit (see SECURITY.md).
# Defensive: release/signing keys (AUR, GPG, SSH) live outside the repo;
# these patterns make an accidental `git add` of one a no-op.
*.pem
*.key
*.pkcs12
*.p12
id_rsa
id_ecdsa
id_ed25519
*_rsa
*_ecdsa
*_ed25519
aur_key*

# Internal strategy doc — kept locally for reference, not published.
PROJECT_PLAN.md
