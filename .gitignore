# Build outputs
/bin/
/dist/
*.exe
*.test
*.out

# Go-specific
# vendor/ IS committed — builds run from it (-mod=vendor), per the
# supply-chain policy in CLAUDE.md.
*.prof
coverage.txt
coverage.html
*.cover

# eBPF build artifacts
# Note: bpf2go-generated .go files ARE committed (per V0.1_SPEC.md §3.1)
# but the intermediate .o objects are not. vmlinux.h is regenerated
# by `make bpf` from the local kernel's BTF; keeping it out of the
# repo avoids committing a 6+MB host-specific file.
*.bpf.o
/internal/inject/ebpf/gen/*.o
/bpf/vmlinux.h

# Test artifacts
/tmp/
/test/integration/tmp/

# Example deps and caches
**/node_modules/
**/package-lock.json
**/__pycache__/
**/.pytest_cache/

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Direnv / env files
.envrc
.env
.env.local

# faultkit-specific runtime artifacts that should never be committed
# (per-run CAs are written to OS temp dirs, but defensively ignore here too)
faultkit-ca-*.pem
*.faultkit-trace
report.json
